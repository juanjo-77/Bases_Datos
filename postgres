-- =============================================
-- 1. TABLA ESPECIALIDADES (se crea primero)
-- porque doctores depende de ella
-- =============================================
CREATE TABLE especialidades (
  id SERIAL PRIMARY KEY,
  nombre VARCHAR(100) NOT NULL
);

-- =============================================
-- 2. TABLA DOCTORES
-- especialidad_id conecta con especialidades
-- =============================================
CREATE TABLE doctores (
  id SERIAL PRIMARY KEY,
  nombre VARCHAR(100) NOT NULL,
  apellido VARCHAR(100) NOT NULL,
  email VARCHAR(100) UNIQUE NOT NULL,
  edad INT NOT NULL,
  -- ↓ ESTA LINEA CONECTA DOCTORES CON ESPECIALIDADES ↓
  especialidad_id INT REFERENCES especialidades(id)
);

-- =============================================
-- 3. TABLA ACUDIENTES
-- =============================================
CREATE TABLE acudientes (
  id SERIAL PRIMARY KEY,
  nombre VARCHAR(100) NOT NULL,
  apellido VARCHAR(100) NOT NULL,
  email VARCHAR(100) UNIQUE NOT NULL,
  edad INT NOT NULL
);

-- =============================================
-- 4. TABLA USUARIOS
-- =============================================
CREATE TABLE usuarios (
  id SERIAL PRIMARY KEY,
  nombre VARCHAR(100) NOT NULL,
  apellido VARCHAR(100) NOT NULL,
  email VARCHAR(100) UNIQUE NOT NULL,
  edad INT NOT NULL
);

